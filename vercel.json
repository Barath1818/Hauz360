{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/assets/(.*)", "destination": "/dist/client/assets/$1" },
    { "source": "/(.*)", "destination": "/server.js" }
  ],
  "functions": {
    "server.js": {
      "includeFiles": "dist/**",
      "runtime": "nodejs20.x"
    }
  }
}